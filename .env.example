# 合同 AI 审查与知识库检索 — 环境变量示例
# 复制为 .env 后填入真实值。.env 已在 .gitignore 中，不要提交。

# ============================================================
# LLM 后端：二选一
# ============================================================
# 选项 A：AWS Bedrock（推荐 — 用 IAM 凭证，无需 API key）
USE_BEDROCK=true
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
BEDROCK_REGION=us-east-1
# 也可省略 BEDROCK_REGION，让 SDK 用 AWS_REGION / AWS_DEFAULT_REGION

# 选项 B：Anthropic 官方 API（USE_BEDROCK=false 时启用）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# ============================================================
# Embedding 提供方（默认本地模型，无需 OpenAI key）
# ============================================================
USE_LOCAL_EMBEDDINGS=true
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# 用 OpenAI Embedding 时把 USE_LOCAL_EMBEDDINGS 设 false 并填下面两项
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ============================================================
# 检索参数（一般不需要改）
# ============================================================
VECTOR_TOP_K=10
BM25_TOP_K=10
RERANK_TOP_K=6

# ============================================================
# 路径
# ============================================================
PDF_PATH=data/AI知识库-综合测试文档.pdf
OUTPUT_DIR=outputs
CHROMA_PERSIST_DIR=outputs/chroma_db
