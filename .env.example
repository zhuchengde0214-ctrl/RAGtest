# 合同 AI 审查与知识库检索 — 环境变量示例
# 复制为 .env 后填入真实值。.env 已在 .gitignore 中，不要提交。

# ============================================================
# LLM 后端：二选一
# ============================================================
# 选项 A：AWS Bedrock（推荐 — 用 IAM 凭证，无需 API key）
USE_BEDROCK=true
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
BEDROCK_LITE_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_REGION=us-east-1
# 也可省略 BEDROCK_REGION，让 SDK 用 AWS_REGION / AWS_DEFAULT_REGION

# 选项 B：Anthropic 官方 API（USE_BEDROCK=false 时启用）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_LITE_MODEL=claude-haiku-4-5

# ============================================================
# Embedding 提供方（按优先级：Bedrock Cohere → 本地 → OpenAI）
# ============================================================
# 推荐：AWS Bedrock 的 Cohere 多语种 embedding（中文友好 + 复用 IAM 凭证）
USE_BEDROCK_EMBEDDING=true
BEDROCK_EMBEDDING_MODEL=cohere.embed-multilingual-v3

# 备选 1：本地 sentence-transformers（USE_BEDROCK_EMBEDDING=false 时启用）
USE_LOCAL_EMBEDDINGS=true
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# 备选 2：OpenAI（USE_BEDROCK_EMBEDDING + USE_LOCAL_EMBEDDINGS 都为 false 时启用）
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ============================================================
# 检索参数（一般不需要改）
# ============================================================
VECTOR_TOP_K=10
BM25_TOP_K=10
RERANK_TOP_K=6

# ============================================================
# 路径
# ============================================================
PDF_PATH=data/AI知识库-综合测试文档.pdf
OUTPUT_DIR=outputs
CHROMA_PERSIST_DIR=outputs/chroma_db
