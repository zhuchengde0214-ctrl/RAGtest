# 合同 AI 审查与知识库检索 — 环境配置

# ============================================================
# LLM API 配置（至少配置一个）
# ============================================================

# Anthropic Claude API（推荐 — 用于 OCR 文本提取、问答、审查）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI API（用于 Embedding，可选）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ============================================================
# 本地 Embedding 备选（不依赖 OpenAI API）
# ============================================================
# 如果设置了 USE_LOCAL_EMBEDDINGS=true，将使用 sentence-transformers
USE_LOCAL_EMBEDDINGS=false
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ============================================================
# 检索参数
# ============================================================
VECTOR_TOP_K=8
BM25_TOP_K=8
RERANK_TOP_K=5
HYBRID_WEIGHT_VECTOR=0.5
HYBRID_WEIGHT_BM25=0.5

# ============================================================
# 文件路径
# ============================================================
PDF_PATH=../data/AI知识库-综合测试文档.pdf
OUTPUT_DIR=../outputs
CHROMA_PERSIST_DIR=../data/chroma_db
